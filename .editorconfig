root = true

# ---------------------------------------------------------------------------
# Allgemein
# ---------------------------------------------------------------------------
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml,json,xml,axaml,csproj,props,targets,config}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Zwei Leerzeichen am Zeilenende = harter Umbruch.

# ---------------------------------------------------------------------------
# C# — Kanon-Pflichten (siehe CLAUDE.md):
#   - file-scoped namespaces erzwingen
#   - Accessibility-Modifier erzwingen
# Beides als Warning; Directory.Build.props hat TreatWarningsAsErrors=true,
# damit wird daraus effektiv ein Build-Bruch.
# ---------------------------------------------------------------------------
[*.cs]
csharp_style_namespace_declarations = file_scoped:warning
dotnet_style_require_accessibility_modifiers = always:warning

# var-Style: bei eingebauten Typen explizit, sonst freie Wahl. Spiegelt den
# Stil des bestehenden Codes (string x = ..., var dlg = new ...).
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:silent

# using-Direktiven ausserhalb des namespace (kompatibel mit file-scoped).
csharp_using_directive_placement = outside_namespace:suggestion

# Klammern-Stil (Allman) — passt zum existierenden Code.
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_cast = false
csharp_space_around_binary_operators = before_and_after
