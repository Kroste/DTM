<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DTM.ViewModels"
        xmlns:cfg="using:DTM.Config"
        mc:Ignorable="d"
        x:Class="DTM.Views.ConnectionManagerWindow"
        x:DataType="vm:ConnectionManagerViewModel"
        Title="Verbindungen verwalten"
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly">

    <Grid RowDefinitions="Auto,*">

        <!-- Titelleiste -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto" Height="36">
                <TextBlock Grid.Column="0"
                           Text="Verbindungen verwalten" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="14,0"
                           IsHitTestVisible="False" />
                <Button Grid.Column="1" Classes="titleBtn close"
                        Click="OnTitleClose" Content="&#x2715;" />
            </Grid>
        </Border>

        <!-- Inhalt -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto,Auto,Auto" Margin="16">

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Connections}"
                      SelectedItem="{Binding SelectedConnection, Mode=TwoWay}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Typ"             Binding="{Binding Key}"              Width="80" />
                    <DataGridTextColumn Header="Server"          Binding="{Binding Server}"            Width="*" />
                    <DataGridTextColumn Header="Benutzer"        Binding="{Binding User}"              Width="130" />
                    <DataGridTextColumn Header="Datenbank"       Binding="{Binding Database}"          Width="100" />
                    <DataGridTextColumn Header="ConnectionString" Binding="{Binding ConnectionString}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,10,0,6">
                <Button Content="Neu"        Click="OnAdd"    Width="90" />
                <Button Content="Bearbeiten" Click="OnEdit"   Width="90" />
                <Button Content="Löschen"    Click="OnDelete" Width="90" />
            </StackPanel>

            <TextBlock Grid.Row="2" FontSize="11" Opacity="0.6"
                       Text="Verbindungen werden in %APPDATA%\DTM\connections.json verschlüsselt gespeichert. Änderungen werden beim nächsten Start übernommen." />

            <!-- Separator -->
            <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Margin="0,12,0,0" Padding="0,12,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="130,*">
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,10" Text="FOC-SQL Modul" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Samba-Quelle (Glob)"
                               VerticalAlignment="Center" Margin="0,0,8,6" />
                    <TextBox   Grid.Row="1" Grid.Column="1"
                               Text="{Binding SambaSource, Mode=TwoWay}"
                               Watermark="leer = eingebauter Default"
                               Margin="0,0,0,6" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Modulpfad (Override)"
                               VerticalAlignment="Center" Margin="0,0,8,6" />
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding ModulePath, Mode=TwoWay}"
                               Watermark="leer = Samba-Logik aktiv"
                               Margin="0,0,0,6" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Update-Quelle"
                               VerticalAlignment="Center" Margin="0,0,8,6" />
                    <TextBox   Grid.Row="3" Grid.Column="1"
                               Text="{Binding UpdateSource, Mode=TwoWay}"
                               Watermark="UNC-Pfad zum Update-Verzeichnis (leer = kein Check)"
                               Margin="0,0,0,6" />

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center"
                                   Text="Gespeichert in %APPDATA%\DTM\settings.json — beim nächsten Start aktiv." />
                        <Button Content="Speichern" Click="OnSaveFocSql" Width="100" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
