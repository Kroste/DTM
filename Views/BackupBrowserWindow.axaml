<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DTM.ViewModels"
        xmlns:term="using:DTM.Data.Terminal"
        x:Class="DTM.Views.BackupBrowserWindow"
        x:DataType="vm:BackupBrowserViewModel"
        Title="Backup-Browser"
        Width="780" Height="540"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- Titelleiste -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto" Height="36">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="14,0"
                            IsHitTestVisible="False">
                    <TextBlock Text="&#x2913;" FontSize="13"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="Backup-Browser" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Classes="titleBtn close"
                        Click="OnTitleClose" Content="&#x2715;" />
            </Grid>
        </Border>

        <!-- Inhalt -->
        <Grid Grid.Row="1" Margin="20,16,20,16" RowDefinitions="Auto,Auto,*,Auto">

            <!-- Kopf: DB-Name -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Classes="infoLabel" Text="Datenbank" />
                <TextBlock Grid.Column="1" Classes="infoValue"
                           Text="{Binding DatabaseName}" FontWeight="Bold" />
            </Grid>

            <!-- Fehler-Hinweis -->
            <Border Grid.Row="1" Margin="0,14,0,0" Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" FontSize="12" />
            </Border>

            <!-- Backup-Liste oder Spinner -->
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Lade Backup-Liste vom SQL-Server …"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13" HorizontalAlignment="Center" />
                    <TextBlock Text="(Modul-Import + Get-ChildItem, dauert beim Erstaufruf ein paar Sekunden)"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" HorizontalAlignment="Center" />
                </StackPanel>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True"
                        IsVisible="{Binding !IsLoading}">
                    <DataGrid ItemsSource="{Binding Backups}"
                              SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datei" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Datum" Binding="{Binding LastWriteTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160" />
                            <DataGridTextColumn Header="Größe" Binding="{Binding SizeDisplay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                           IsVisible="{Binding HasBackups}">
                    <Run Text="&#x26A0;" Foreground="{DynamicResource DangerBrush}" />
                    <Run Text=" Restore ueberschreibt die Datenbank vollstaendig (WITH REPLACE)." />
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Schliessen" Click="OnCancel" MinWidth="100" />
                    <Button x:Name="RestoreButton"
                            Content="Restore ausfuehren"
                            Click="OnRestore"
                            MinWidth="170"
                            IsEnabled="{Binding SelectedBackup, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Classes="action danger" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>

</Window>
