<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrl="clr-namespace:DTM.Views.Controls"
             mc:Ignorable="d"
             x:Class="DTM.Views.Controls.ConsoleControl">

    <Grid RowDefinitions="*,Auto" Background="#0A0E12">
        <!-- AnsiConsole rendert pro Zeile einen eigenen TextBlock mit Inlines.
             Umgeht den SelectableTextBlock-Inlines-Bug, unterstützt aber volle
             ANSI-Farben (SGR, 256-Color, Truecolor). -->
        <ctrl:AnsiConsole Name="Output" Grid.Row="0" />

        <Border Grid.Row="1" BorderBrush="#1E2730" BorderThickness="0,1,0,0" Background="#0A0E12">
            <Grid ColumnDefinitions="Auto,*" Margin="12,7,12,8">
                <TextBlock Grid.Column="0"
                           Text="&#x276F;"
                           Foreground="#2DD4BF"
                           FontFamily="Cascadia Mono, Consolas, Menlo, Monospace"
                           FontSize="14"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Name="InputBox"
                         Background="Transparent"
                         Foreground="#E8EDF2"
                         BorderThickness="0"
                         CaretBrush="#2DD4BF"
                         FontFamily="Cascadia Mono, Consolas, Menlo, Monospace"
                         FontSize="13"
                         PlaceholderText="Befehl eingeben…"
                         KeyDown="OnInputKeyDown" />
            </Grid>
        </Border>
    </Grid>

</UserControl>
