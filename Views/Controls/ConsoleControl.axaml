<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="DTM.Views.Controls.ConsoleControl">

    <Grid RowDefinitions="*,Auto" Background="Black">
        <!-- Read-only TextBox statt SelectableTextBlock+Inlines:
             - kein "HasComplexContent"-Bug, kein flackerndes Re-Layout
             - AppendText ist effizient und reicht den Caret bis ans Ende durch
             - Text bleibt selektier-/kopierbar (Strg+C, Strg+A)
             - Trade-off: keine farbigen Sub-Strings mehr; alles in einer Farbe.
               Wir behelfen uns über Prefixe ([NOTICE], [ERR]) für Lesbarkeit. -->
        <TextBox Name="OutputBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 Background="Black"
                 Foreground="#E0E0E0"
                 BorderThickness="0"
                 CaretBrush="Transparent"
                 FontFamily="Cascadia Mono, Consolas, Menlo, Monospace"
                 FontSize="12"
                 Padding="6" />

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Background="Black" Margin="6,2,6,4">
            <TextBlock Grid.Column="0"
                       Text=">"
                       Foreground="LightGreen"
                       FontFamily="Cascadia Mono, Consolas, Menlo, Monospace"
                       FontSize="14"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBox Grid.Column="1"
                     Name="InputBox"
                     Background="Black"
                     Foreground="White"
                     BorderThickness="0"
                     CaretBrush="White"
                     FontFamily="Cascadia Mono, Consolas, Menlo, Monospace"
                     FontSize="12"
                     KeyDown="OnInputKeyDown" />
        </Grid>
    </Grid>

</UserControl>
