<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DTM.ViewModels"
        xmlns:term="using:DTM.Data.Terminal"
        x:Class="DTM.Views.OracleRestoreSelectWindow"
        x:DataType="vm:OracleRestoreSelectViewModel"
        Title="Oracle Restore-Vorschau"
        Width="780" Height="560"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- Titelleiste -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto" Height="36">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="14,0"
                            IsHitTestVisible="False">
                    <TextBlock Text="&#x21BA;" FontSize="13"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="Oracle Restore-Vorschau" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Classes="titleBtn close"
                        Click="OnTitleClose" Content="&#x2715;" />
            </Grid>
        </Border>

        <!-- Inhalt -->
        <Grid Grid.Row="1" Margin="20,16,20,16" RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Header: DB-Name + PDB-Liste -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="infoLabel" Text="Datenbank" />
                <TextBlock Grid.Row="0" Grid.Column="1" Classes="infoValue"
                           Text="{Binding DatabaseName}" FontWeight="Bold" />
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="infoLabel"
                           Text="PDBs" Margin="0,4,0,0" />
                <ItemsControl Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                              ItemsSource="{Binding Pdbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemSpacing="6" LineSpacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="term:OraclePdb">
                            <Border CornerRadius="4" Padding="8,2"
                                    Background="{DynamicResource SurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}">
                                    <Run Text="{Binding Name}" />
                                    <Run Text=" (ConID " Foreground="{DynamicResource TextMutedBrush}" />
                                    <Run Text="{Binding ConId}" Foreground="{DynamicResource TextMutedBrush}" />
                                    <Run Text=")" Foreground="{DynamicResource TextMutedBrush}" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Multi-PDB-Warnung (rot, prominent) -->
            <Border Grid.Row="1" Margin="0,14,0,0" Padding="14,10"
                    CornerRadius="8"
                    Background="#3A1F1F"
                    BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1"
                    IsVisible="{Binding HasMultiplePdbs}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="&#x26A0;" FontSize="18"
                               Foreground="{DynamicResource DangerBrush}"
                               VerticalAlignment="Top" />
                    <StackPanel Spacing="3">
                        <TextBlock Text="Mehrere PDBs in dieser CDB!"
                                   FontWeight="Bold" FontSize="13"
                                   Foreground="{DynamicResource DangerBrush}" />
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Restore-Snapshot faehrt die GESAMTE Container-DB herunter (SHUTDOWN IMMEDIATE) und stellt sie auf den gewaehlten Restore Point zurueck — ALLE PDBs sind betroffen, nicht nur die gewaehlte Datenbank." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Fehler-/Hinweis-Zeile -->
            <Border Grid.Row="2" Margin="0,14,0,0" Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" FontSize="12" />
            </Border>

            <!-- Restore-Points: Loading-Spinner ODER DataGrid -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <!-- Spinner -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="10" IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Lade Restore-Points per SSH …"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13" HorizontalAlignment="Center" />
                    <TextBlock Text="(Modul-Import + SQL*Plus, dauert beim Erstaufruf ein paar Sekunden)"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True"
                        IsVisible="{Binding !IsLoading}">
                    <DataGrid ItemsSource="{Binding RestorePoints}"
                              SelectedItem="{Binding SelectedRestorePoint, Mode=TwoWay}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Zeit" Binding="{Binding Time}" Width="180" />
                            <DataGridTextColumn Header="Guaranteed" Binding="{Binding Guaranteed}" Width="110" />
                            <DataGridTextColumn Header="ConID" Binding="{Binding ConId}" Width="80" />
                            <DataGridTextColumn Header="SCN" Binding="{Binding Scn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Footer-Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
                <Button Content="Abbrechen" Click="OnCancel" MinWidth="100" />
                <Button x:Name="RestoreButton" Content="Restore ausfuehren"
                        Click="OnRestore"
                        MinWidth="160"
                        IsEnabled="{Binding HasRestorePoints}"
                        Classes="action danger" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>
