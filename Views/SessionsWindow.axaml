<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DTM.ViewModels"
        mc:Ignorable="d"
        x:Class="DTM.Views.SessionsWindow"
        x:DataType="vm:SessionsViewModel"
        Title="Sessions"
        Width="800" Height="490"
        MinWidth="600" MinHeight="360"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*">

        <!-- Titelleiste -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto" Height="36">
                <TextBlock Grid.Column="0"
                           Text="Sessions" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="14,0"
                           IsHitTestVisible="False" />
                <Button Grid.Column="1" Classes="titleBtn close"
                        Click="OnTitleClose" Content="&#x2715;" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Sessions}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                <DataGridTextColumn Header="Maschine" Binding="{Binding Maschine}" Width="*" />
                <DataGridTextColumn Header="Programm" Binding="{Binding Program}" Width="*" />
                <DataGridTextColumn Header="Status"   Binding="{Binding Status}"   Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</Window>
