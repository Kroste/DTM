{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DTM.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Release)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DTM.csproj",
                "-c",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DTM.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/DTM.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            // App ohne Debugger starten — funktioniert auch ohne installierte
            // C#-Extension (umgeht das "coreclr"-Problem auf Code-OSS/Codium).
            // Aufruf: Ctrl+Shift+P -> "Tasks: Run Task" -> "DTM ausfuehren".
            "label": "DTM ausfuehren",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/DTM.csproj"
            ],
            "options": {
                "env": {
                    "DOTNET_ROOT": "${env:HOME}/.dotnet",
                    "PATH": "${env:HOME}/.dotnet:${env:HOME}/.dotnet/tools:${env:PATH}"
                }
            },
            "presentation": {
                "panel": "dedicated",
                "focus": false,
                "reveal": "always"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
