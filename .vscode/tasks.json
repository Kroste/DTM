{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DTM.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Release)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DTM.csproj",
                "-c",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DTM.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/DTM.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            // App ohne Debugger starten — funktioniert auch ohne installierte
            // C#-Extension (umgeht das "coreclr"-Problem auf Code-OSS/Codium).
            // Aufruf: Ctrl+Shift+P -> "Tasks: Run Task" -> "DTM ausfuehren".
            "label": "DTM ausfuehren",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/DTM.csproj"
            ],
            "options": {
                "env": {
                    "DOTNET_ROOT": "${env:HOME}/.dotnet",
                    "PATH": "${env:HOME}/.dotnet:${env:HOME}/.dotnet/tools:${env:PATH}"
                }
            },
            "presentation": {
                "panel": "dedicated",
                "focus": false,
                "reveal": "always"
            },
            "problemMatcher": "$msCompile"
        },
        {
            // Loescht bin/ und obj/ in DTM und DTM.Tests rekursiv.
            // Cross-Platform: rm auf Linux/macOS, Remove-Item via PowerShell auf Windows.
            "label": "hard clean (bin + obj)",
            "type": "shell",
            "linux": {
                "command": "rm -rf bin obj DTM.Tests/bin DTM.Tests/obj"
            },
            "osx": {
                "command": "rm -rf bin obj DTM.Tests/bin DTM.Tests/obj"
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-Command",
                    "Remove-Item -Recurse -Force bin,obj,DTM.Tests\\bin,DTM.Tests\\obj -ErrorAction SilentlyContinue"
                ]
            },
            "problemMatcher": []
        },
        {
            // Oeffnet das aktuelle Info-Logfile mit dem Default-Programm.
            // Pfad orientiert sich am NLog-${basedir}/logs unter bin/Debug/net10.0.
            "label": "Logfile info oeffnen",
            "type": "shell",
            "linux": {
                "command": "xdg-open bin/Debug/net10.0/logs/info.log"
            },
            "osx": {
                "command": "open bin/Debug/net10.0/logs/info.log"
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-Command",
                    "Start-Process bin\\Debug\\net10.0\\logs\\info.log"
                ]
            },
            "problemMatcher": []
        },
        {
            // Oeffnet das aktuelle Error-Logfile mit dem Default-Programm.
            "label": "Logfile error oeffnen",
            "type": "shell",
            "linux": {
                "command": "xdg-open bin/Debug/net10.0/logs/error.log"
            },
            "osx": {
                "command": "open bin/Debug/net10.0/logs/error.log"
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-Command",
                    "Start-Process bin\\Debug\\net10.0\\logs\\error.log"
                ]
            },
            "problemMatcher": []
        }
    ]
}
