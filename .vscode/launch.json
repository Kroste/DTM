{
    "version": "0.2.0",
    "configurations": [
        {
            // Debug-Launch fuer DTM unter Linux (insb. Bazzite + Toolbx,
            // wo dotnet nicht im System-PATH liegt sondern unter ~/.dotnet).
            "name": "DTM (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net10.0/DTM.dll",
            "args": [],
            "cwd": "${workspaceFolder}/bin/Debug/net10.0",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "DOTNET_ROOT": "${env:HOME}/.dotnet",
                "PATH": "${env:HOME}/.dotnet:${env:HOME}/.dotnet/tools:${env:PATH}"
            }
        },
        {
            "name": "DTM (Release)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (Release)",
            "program": "${workspaceFolder}/bin/Release/net10.0/DTM.dll",
            "args": [],
            "cwd": "${workspaceFolder}/bin/Release/net10.0",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "DOTNET_ROOT": "${env:HOME}/.dotnet",
                "PATH": "${env:HOME}/.dotnet:${env:HOME}/.dotnet/tools:${env:PATH}"
            }
        },
        {
            "name": ".NET Attach (laufender Prozess)",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
